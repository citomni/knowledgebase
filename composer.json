{
	"name": "citomni/knowledgebase",
	"description": "Lean knowledge base and grounded question-answering package for CitOmni: Structured document ingest, chunking, hybrid retrieval, synonym expansion, optional reranking, and AI-generated answers grounded in retrieved context.",
	"type": "library",
	"license": "MIT",
	"homepage": "https://github.com/citomni/knowledgebase",
	"keywords": [
		"ai",
		"knowledge-base",
		"question-answering",
		"retrieval",
		"hybrid-retrieval",
		"rag",
		"vector-embedding",
		"semantic-search",
		"fulltext-search",
		"synonyms",
		"llm",
		"php",
		"high-performance",
		"low-overhead",
		"deterministic",
		"php8",
		"citomni",
		"citomni-framework",
		"citomni-php",
		"green-by-design",
		"deterministic-config",
		"framework"
	],
	"require": {
		"php": "^8.2",
		"ext-json": "*",
		"citomni/kernel": "^1.0",
		"citomni/infrastructure": "^1.0",
		"citomni/vectorembedding": "^1.0",
		"citomni/helloai": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"CitOmni\\KnowledgeBase\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"CitOmni\\KnowledgeBase\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"phpstan/phpstan": "^1.11"
	},
	"suggest": {
		"ext-opcache": "Better performance in production.",
		"citomni/http": "Optional. Install when using KnowledgeBase from HTTP applications.",
		"citomni/cli": "Optional. Install when using KnowledgeBase from CLI applications or package-provided commands."
	},
	"support": {
		"issues": "https://github.com/citomni/knowledgebase/issues",
		"source": "https://github.com/citomni/knowledgebase",
		"docs": "https://github.com/citomni/knowledgebase#readme"
	},
	"authors": [
		{
			"name": "Lars Grove Mortensen",
			"homepage": "https://www.citomni.com"
		}
	],
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true
	},
	"archive": {
		"exclude": [
			"/.github",
			"/docs",
			"/tests",
			"/dev",
			"/examples",
			"/vendor",
			"/.editorconfig",
			"/.gitattributes",
			"/.gitignore",
			"/phpunit.xml*",
			"/.idea",
			"/.vscode",
			"/Makefile"
		]
	}
}